# LockSafe Mobile App Environment Variables
# Copy this file to .env and fill in your values
#
# ⚠️  NEVER commit .env to version control!
# ⚠️  Replace ALL placeholder values before production builds

# ========================================
# API Configuration
# ========================================
API_URL=https://locksafe.uk
EXPO_PUBLIC_API_URL=https://locksafe.uk

# ========================================
# Stripe Configuration
# ========================================
# Publishable key (safe for client-side)
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_xxx for development, pk_live_xxx for production
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ========================================
# OneSignal Push Notifications
# ========================================
# Get from: https://app.onesignal.com → Settings → Keys & IDs
EXPO_PUBLIC_ONESIGNAL_APP_ID=xxx-xxx-xxx

# ========================================
# Google Maps
# ========================================
# Get from: https://console.cloud.google.com/apis/credentials
# Required APIs to enable:
#   - Maps SDK for Android
#   - Maps SDK for iOS
#   - Geocoding API
#   - Places API (optional, for address autocomplete)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxx
