{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "development",
        "API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_xxx",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": "xxx-xxx-xxx",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaxxx"
      }
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "development",
        "API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_xxx",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": "xxx-xxx-xxx",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaxxx"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "preview",
        "API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_xxx",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": "xxx-xxx-xxx",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "AIzaxxx"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "credentialsSource": "remote"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_API_URL": "https://locksafe.uk",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_live_YOUR_LIVE_STRIPE_KEY",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": "YOUR_ONESIGNAL_APP_ID",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "YOUR_PRODUCTION_GOOGLE_MAPS_KEY"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID",
        "ascAppId": "YOUR_ASC_APP_ID",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
